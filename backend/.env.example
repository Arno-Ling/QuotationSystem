# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=mold_procurement

# JWT Configuration
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI Configuration (for LLM)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
EMAIL_FROM=your-email@gmail.com

# Redis Configuration (optional, for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Application Configuration
APP_NAME=Mold Procurement System
APP_VERSION=1.0.0
DEBUG=True
LOG_LEVEL=INFO
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# File Upload
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
UPLOAD_DIR=./uploads

# Exception Agent Configuration
EXCEPTION_AGENT_MODEL=gpt-4
EXCEPTION_AGENT_TEMPERATURE=0.2
EXCEPTION_AGENT_MAX_STEPS=15
CHROMA_DB_PATH=./chroma_db/exception_agent
EXCEPTION_AGENT_RAG_TOP_K=5
